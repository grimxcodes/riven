consistof "std.rv"

riven core {

    stamp("Riven V1")

    numbers = [5, 10, 15]

    stamp(numbers[0])

    stamp(numbers[1])

    stamp(numbers[2])

    craft add(a, b) {

        result = a + b

        return result

    }

    total = add(20, 30)

    stamp(total)

    if total == 50 {

        stamp("math works")

    }

    i = 0

    flow i < 3 {

        stamp(numbers[i])

        i = i + 1

    }

    stamp("enter value")

    value = input()

    stamp(value)

}
