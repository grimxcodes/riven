riven core {

    craft square(x) {

        result = x + x

        return result

    }

    craft calculate(n) {

        temp = square(n)

        final = temp + 5

        return final

    }

    value = calculate(10)

    stamp(value)

    if value == 25 {

        stamp("nested calls work")

    }

    i = 3

    flow i > 0 {

        stamp(i)

        i = i - 1

    }

    stamp("v1 growing")

}
