riven core {

    craft add(a, b) {

        result = a + b

        return result

    }

    craft test(n) {

        if n > 5 {

            stamp("big")

        }

        else {

            stamp("small")

        }

        i = 0

        flow i < n {

            stamp(i)

            i = i + 1

        }

    }

    value = add(7, 8)

    stamp(value)

    test(3)

    test(8)

}
