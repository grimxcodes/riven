riven core {

    # multiple params

    craft add(a, b) {

        result = a + b

        return result

    }

    total = add(10, 20)

    stamp(total)

    # else support

    if total == 50 {

        stamp("wrong")

    }

    else {

        stamp("else works")

    }

    # comments support

    # this should not crash

    i = 0

    flow i < 3 {

        stamp(i)

        i = i + 1

    }

}
