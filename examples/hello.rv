riven core {

    craft greet(name) {

        stamp(name)

    }

    craft add(a) {

        result = a + 10

        stamp(result)

    }

    craft countdown(limit) {

        i = limit

        flow i > 0 {

            stamp(i)

            i = i - 1

        }

    }

    greet("Ansh")

    add(5)

    countdown(5)

    x = 100

    y = x - 50

    stamp(y)

    if y == 50 {

        stamp("half")

    }

    if y < 100 {

        stamp("smaller")

    }

}
