riven core {

    craft greet(name) {

        stamp(name)

    }

    craft add(a) {

        result = a + 10

        stamp(result)

    }

    craft loopTest(limit) {

        i = 0

        flow i < limit {

            stamp(i)

            i = i + 1

        }

    }

    greet("Ansh")

    add(5)

    loopTest(3)

    x = 20

    y = x + 30

    stamp(y)

    if y == 50 {

        stamp("correct")

    }

    if y > 10 {

        stamp("big")

    }

}
